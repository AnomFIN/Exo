# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── PHP / Runtime ─────────────────────────────────────────────────────────────
# Environment file (contains secrets – never commit)
.env
# Installer lock (generated after successful install)
storage/install.lock
# Flat-file storage data (user-generated, not source code)
storage/pages/*.json
storage/settings.json

# ── Next.js (frontend-nextjs/) ────────────────────────────────────────────────
frontend-nextjs/node_modules
frontend-nextjs/.next/
frontend-nextjs/out/
frontend-nextjs/build
frontend-nextjs/.pnp
frontend-nextjs/.pnp.*
frontend-nextjs/.yarn/*
!frontend-nextjs/.yarn/patches
!frontend-nextjs/.yarn/plugins
!frontend-nextjs/.yarn/releases
!frontend-nextjs/.yarn/versions
frontend-nextjs/coverage
frontend-nextjs/*.tsbuildinfo
frontend-nextjs/next-env.d.ts
frontend-nextjs/.vercel

# ── Misc ──────────────────────────────────────────────────────────────────────
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
